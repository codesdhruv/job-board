---
interface Props {
  title?: string;
}

const { title = 'Admin — SarkariNaukriBoard' } = Astro.props;

const path = Astro.url.pathname;
const showNav = path !== '/admin/login';

const isActive = (href: string) =>
  href === '/admin/dashboard'
    ? path === '/admin/dashboard'
    : path.startsWith(href);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --anav-height: 56px;
        --anav-bg: #1a1d23;
        --anav-border-color: #2d3748;
        --anav-text: #a0aec0;
        --anav-text-active: #ffffff;
        --anav-accent: #FF6B00;
        --anav-hover-bg: #2d3748;
        --anav-active-bg: rgba(255, 107, 0, 0.12);
      }

      body {
        margin: 0;
        font-family: Geist, system-ui, sans-serif;
        background: #0f1117;
        color: var(--anav-text);
      }

      /* ── Navbar ── */
      .anav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: var(--anav-height);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        background: var(--anav-bg);
        border-bottom: 1px solid var(--anav-border-color);
        z-index: 40;
      }

      .anav-brand {
        font-size: 15px;
        font-weight: 600;
        color: #ffffff;
        text-decoration: none;
        flex-shrink: 0;
      }

      .anav-links {
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .anav-right {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-shrink: 0;
      }

      .anav-link {
        color: var(--anav-text);
        padding: 8px 14px;
        border-radius: 6px;
        font-size: 14px;
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }

      .anav-link:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      .anav-link.active {
        background: var(--anav-active-bg);
        color: var(--anav-accent);
        font-weight: 500;
        border-bottom: 2px solid var(--anav-accent);
      }

      /* ── Theme toggle ── */
      .anav-theme-btn {
        background: none;
        border: none;
        color: var(--anav-text);
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: background 0.15s, color 0.15s;
      }

      .anav-theme-btn:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      /* ── Logout ── */
      .anav-logout-desktop form,
      .anav-mobile-logout form {
        margin: 0;
      }

      .anav-logout {
        background: none;
        border: none;
        color: #fc8181;
        font-size: 14px;
        padding: 8px 14px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        font-family: inherit;
      }

      .anav-logout:hover {
        background: rgba(252, 129, 129, 0.08);
        color: #feb2b2;
      }

      /* ── Hamburger ── */
      .anav-hamburger {
        display: none;
        background: none;
        border: none;
        color: #ffffff;
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        align-items: center;
        transition: background 0.15s;
      }

      .anav-hamburger:hover {
        background: var(--anav-hover-bg);
      }

      /* ── Mobile dropdown ── */
      .anav-mobile-menu {
        position: fixed;
        top: var(--anav-height);
        left: 0;
        right: 0;
        background: var(--anav-bg);
        border-bottom: 1px solid var(--anav-border-color);
        padding: 8px 0;
        display: none;
        z-index: 39;
      }

      .anav-mobile-menu.open {
        display: block;
      }

      .anav-mobile-link {
        display: block;
        padding: 12px 20px;
        font-size: 15px;
        color: var(--anav-text);
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: background 0.15s, color 0.15s;
      }

      .anav-mobile-link:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      .anav-mobile-link.active {
        border-left-color: var(--anav-accent);
        color: var(--anav-accent);
        background: var(--anav-active-bg);
      }

      .anav-mobile-logout {
        padding: 4px 0 0;
        margin-top: 4px;
        border-top: 1px solid var(--anav-border-color);
      }

      .anav-mobile-logout .anav-logout {
        display: block;
        width: 100%;
        text-align: left;
        padding: 12px 20px;
        border-radius: 0;
      }

      /* ── Page content ── */
      .admin-content {
        padding-top: var(--anav-height);
        min-height: 100vh;
        background: #0f1117;
      }

      /* ── Media queries ── */
      @media (max-width: 768px) {
        .anav-links        { display: none; }
        .anav-hamburger    { display: flex; }
        .anav-logout-desktop { display: none; }
      }

      @media (min-width: 769px) {
        .anav-hamburger    { display: none; }
        .anav-mobile-menu  { display: none !important; }
      }
    </style>
  </head>
  <body>
    {showNav && (
      <>
        <nav class="anav">
          <a href="/admin/dashboard" class="anav-brand">Admin Panel</a>

          <div class="anav-links">
            <a href="/admin/dashboard" class={`anav-link ${isActive('/admin/dashboard') ? 'active' : ''}`}>Dashboard</a>
            <a href="/admin/jobs" class={`anav-link ${isActive('/admin/jobs') && !isActive('/admin/jobs/new') ? 'active' : ''}`}>All Jobs</a>
            <a href="/admin/jobs/new" class={`anav-link ${isActive('/admin/jobs/new') ? 'active' : ''}`}>Add New Job</a>
            <a href="/" target="_blank" rel="noopener" class="anav-link">View Site</a>
          </div>

          <div class="anav-right">
            <button id="anav-theme-btn" class="anav-theme-btn" aria-label="Toggle theme">
              <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>

            <div class="anav-logout-desktop">
              <form method="POST" action="/admin/logout">
                <button type="submit" class="anav-logout">Logout</button>
              </form>
            </div>

            <button id="anav-hamburger" class="anav-hamburger" aria-label="Open menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
          </div>
        </nav>

        <div id="anav-mobile-menu" class="anav-mobile-menu">
          <a href="/admin/dashboard" class={`anav-mobile-link ${isActive('/admin/dashboard') ? 'active' : ''}`}>Dashboard</a>
          <a href="/admin/jobs" class={`anav-mobile-link ${isActive('/admin/jobs') && !isActive('/admin/jobs/new') ? 'active' : ''}`}>All Jobs</a>
          <a href="/admin/jobs/new" class={`anav-mobile-link ${isActive('/admin/jobs/new') ? 'active' : ''}`}>Add New Job</a>
          <a href="/" target="_blank" rel="noopener" class="anav-mobile-link">View Site</a>
          <div class="anav-mobile-logout">
            <form method="POST" action="/admin/logout">
              <button type="submit" class="anav-logout">Logout</button>
            </form>
          </div>
        </div>
      </>
    )}

    <div class="admin-content">
      <slot />
    </div>

    <script>
      // Theme toggle
      const btn = document.getElementById('anav-theme-btn');
      const iconMoon = document.getElementById('icon-moon');
      const iconSun = document.getElementById('icon-sun');

      if (btn && iconMoon && iconSun) {
        // Set initial icon state
        const saved = localStorage.getItem('theme') || 'light';
        if (saved === 'dark') {
          document.documentElement.classList.add('dark');
          iconMoon.style.display = 'none';
          iconSun.style.display = 'block';
        }

        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          iconMoon.style.display = isDark ? 'none' : 'block';
          iconSun.style.display = isDark ? 'block' : 'none';
        });
      }

      // Hamburger menu
      const hamburger = document.getElementById('anav-hamburger');
      const mobileMenu = document.getElementById('anav-mobile-menu');

      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          mobileMenu.classList.toggle('open');
        });

        document.addEventListener('click', (e) => {
          if (!hamburger.contains(e.target as Node) && !mobileMenu.contains(e.target as Node)) {
            mobileMenu.classList.remove('open');
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') mobileMenu.classList.remove('open');
        });
      }
    </script>
  </body>
</html>
