---
interface Props {
  title?: string;
}

const { title = 'Admin — SarkariNaukriBoard' } = Astro.props;

const path = Astro.url.pathname;
const showNav = path !== '/admin/login';

const isActive = (href: string) =>
  href === '/admin/dashboard'
    ? path === '/admin/dashboard'
    : path.startsWith(href);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <script is:inline>
      const t = localStorage.getItem('admin-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --anav-height: 64px;
        --anav-bg: #ffffff;
        --anav-border-color: #ebebeb;
        --anav-text: #4d4d4d;
        --anav-text-active: #171717;
        --anav-hover-bg: #f5f5f5;
        --anav-active-bg: #f5f5f5;
        --page-bg: #fafafa;
        --body-color: #171717;
      }

      [data-theme="dark"] {
        --anav-bg: #111111;
        --anav-border-color: #2e2e2e;
        --anav-text: #a1a1a1;
        --anav-text-active: #ededed;
        --anav-hover-bg: #1f1f1f;
        --anav-active-bg: #1f1f1f;
        --page-bg: #0a0a0a;
        --body-color: #ededed;
      }

      body {
        margin: 0;
        font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
        background: var(--page-bg);
        color: var(--body-color);
        transition: background 0.2s, color 0.2s;
      }

      /* ── Navbar ── */
      .anav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: var(--anav-height);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 24px;
        background: var(--anav-bg);
        border-bottom: 1px solid var(--anav-border-color);
        z-index: 40;
      }

      .anav-brand {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: -0.3px;
        color: var(--anav-text-active);
        text-decoration: none;
        flex-shrink: 0;
      }

      .anav-links {
        display: flex;
        align-items: center;
        gap: 2px;
      }

      .anav-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
      }

      .anav-link {
        color: var(--anav-text);
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 14px;
        text-decoration: none;
        transition: background 0.1s, color 0.1s;
        white-space: nowrap;
        border-bottom: 2px solid transparent;
      }

      .anav-link:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      .anav-link.active {
        background: var(--anav-active-bg);
        color: var(--anav-text-active);
        font-weight: 500;
        border-bottom: 2px solid var(--anav-text-active);
      }

      /* ── Logout ── */
      .anav-logout-desktop form,
      .anav-mobile-logout form {
        margin: 0;
      }

      .anav-logout {
        background: none;
        border: 1px solid var(--anav-border-color);
        color: var(--anav-text);
        font-size: 14px;
        padding: 0 12px;
        height: 32px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.1s, color 0.1s;
        font-family: inherit;
      }

      .anav-logout:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      /* ── Theme toggle ── */
      .anav-theme-toggle {
        background: none;
        border: 1px solid var(--anav-border-color);
        color: var(--anav-text);
        width: 32px;
        height: 32px;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.1s, color 0.1s;
        flex-shrink: 0;
      }

      .anav-theme-toggle:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      .icon-sun, .icon-moon { display: none; }
      [data-theme="dark"] .icon-sun  { display: block; }
      [data-theme="light"] .icon-moon, :root:not([data-theme]) .icon-moon { display: block; }

      /* ── Hamburger ── */
      .anav-hamburger {
        display: none;
        background: none;
        border: 1px solid var(--anav-border-color);
        color: var(--anav-text-active);
        cursor: pointer;
        padding: 6px;
        border-radius: 6px;
        align-items: center;
        transition: background 0.1s;
      }

      .anav-hamburger:hover {
        background: var(--anav-hover-bg);
      }

      /* ── Mobile dropdown ── */
      .anav-mobile-menu {
        position: fixed;
        top: var(--anav-height);
        left: 0;
        right: 0;
        background: var(--anav-bg);
        border-bottom: 1px solid var(--anav-border-color);
        padding: 8px 0;
        display: none;
        z-index: 39;
      }

      .anav-mobile-menu.open {
        display: block;
      }

      .anav-mobile-link {
        display: block;
        padding: 12px 24px;
        font-size: 14px;
        color: var(--anav-text);
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: background 0.1s, color 0.1s;
      }

      .anav-mobile-link:hover {
        background: var(--anav-hover-bg);
        color: var(--anav-text-active);
      }

      .anav-mobile-link.active {
        border-left-color: var(--anav-text-active);
        color: var(--anav-text-active);
        font-weight: 500;
        background: var(--anav-active-bg);
      }

      .anav-mobile-logout {
        padding: 4px 0 0;
        margin-top: 4px;
        border-top: 1px solid var(--anav-border-color);
      }

      .anav-mobile-logout .anav-logout {
        display: block;
        width: 100%;
        text-align: left;
        padding: 12px 24px;
        height: auto;
        border-radius: 0;
        border: none;
        border-top: none;
      }

      /* ── Page content ── */
      .admin-content {
        padding-top: var(--anav-height);
        min-height: 100vh;
        background: var(--page-bg);
      }

      .admin-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 36px 24px;
      }

      /* ── Media queries ── */
      @media (max-width: 768px) {
        .anav-links          { display: none; }
        .anav-hamburger      { display: flex; }
        .anav-logout-desktop { display: none; }
        .admin-page          { padding: 24px 16px; }
      }

      @media (min-width: 769px) {
        .anav-hamburger   { display: none; }
        .anav-mobile-menu { display: none !important; }
      }
    </style>
  </head>
  <body>
    {showNav && (
      <>
        <nav class="anav">
          <a href="/admin/dashboard" class="anav-brand">SarkariNaukriBoard</a>

          <div class="anav-links">
            <a href="/admin/dashboard" class={`anav-link ${isActive('/admin/dashboard') ? 'active' : ''}`}>Dashboard</a>
            <a href="/admin/jobs" class={`anav-link ${isActive('/admin/jobs') && !isActive('/admin/jobs/new') ? 'active' : ''}`}>All Jobs</a>
            <a href="/admin/jobs/new" class={`anav-link ${isActive('/admin/jobs/new') ? 'active' : ''}`}>Add New Job</a>
            <a href="/" target="_blank" rel="noopener" class="anav-link">View Site ↗</a>
          </div>

          <div class="anav-right">
            <button id="anav-theme-toggle" class="anav-theme-toggle" aria-label="Toggle theme">
              <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>

            <div class="anav-logout-desktop">
              <form method="POST" action="/admin/logout">
                <button type="submit" class="anav-logout">Logout</button>
              </form>
            </div>

            <button id="anav-hamburger" class="anav-hamburger" aria-label="Open menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
          </div>
        </nav>

        <div id="anav-mobile-menu" class="anav-mobile-menu">
          <a href="/admin/dashboard" class={`anav-mobile-link ${isActive('/admin/dashboard') ? 'active' : ''}`}>Dashboard</a>
          <a href="/admin/jobs" class={`anav-mobile-link ${isActive('/admin/jobs') && !isActive('/admin/jobs/new') ? 'active' : ''}`}>All Jobs</a>
          <a href="/admin/jobs/new" class={`anav-mobile-link ${isActive('/admin/jobs/new') ? 'active' : ''}`}>Add New Job</a>
          <a href="/" target="_blank" rel="noopener" class="anav-mobile-link">View Site ↗</a>
          <div class="anav-mobile-logout">
            <form method="POST" action="/admin/logout">
              <button type="submit" class="anav-logout">Logout</button>
            </form>
          </div>
        </div>
      </>
    )}

    <div class="admin-content">
      {showNav ? (
        <div class="admin-page">
          <slot />
        </div>
      ) : (
        <slot />
      )}
    </div>

    <script>
      // ── Theme toggle ──
      const root = document.documentElement;
      const saved = localStorage.getItem('admin-theme');
      if (saved) root.setAttribute('data-theme', saved);

      const themeBtn = document.getElementById('anav-theme-toggle');
      if (themeBtn) {
        themeBtn.addEventListener('click', () => {
          const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          localStorage.setItem('admin-theme', next);
        });
      }

      // ── Hamburger ──
      const hamburger = document.getElementById('anav-hamburger');
      const mobileMenu = document.getElementById('anav-mobile-menu');

      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          mobileMenu.classList.toggle('open');
        });

        document.addEventListener('click', (e) => {
          if (!hamburger.contains(e.target as Node) && !mobileMenu.contains(e.target as Node)) {
            mobileMenu.classList.remove('open');
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') mobileMenu.classList.remove('open');
        });
      }
    </script>
  </body>
</html>
