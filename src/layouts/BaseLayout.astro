---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title = 'SarkariNaukriBoard', description, canonical } = Astro.props;

const footerColumns = [
  {
    heading: 'Jobs',
    links: [
      { label: 'All Jobs',         href: '/jobs' },
      { label: 'Government Jobs',  href: '/jobs?type=government' },
      { label: 'PSU / Semi-Govt',  href: '/jobs?type=psu' },
      { label: 'Private Jobs',     href: '/jobs?type=private' },
      { label: 'Freelance / Gig',  href: '/jobs?type=freelance' },
    ],
  },
  {
    heading: 'Browse',
    links: [
      { label: 'By State',   href: '/states' },
      { label: 'UPSC Jobs',  href: '/jobs?q=UPSC' },
      { label: 'SSC Jobs',   href: '/jobs?q=SSC' },
      { label: 'Railways',   href: '/category/railways' },
      { label: 'Banking',    href: '/category/banking' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About',          href: '/about' },
      { label: 'Contact',        href: '/contact' },
      { label: 'Privacy Policy', href: '/privacy-policy' },
      { label: 'Terms of Use',   href: '/terms' },
      { label: 'Sitemap',        href: '/sitemap.xml' },
    ],
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <!-- Inline theme bootstrap: runs before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var dark = stored ? stored === 'dark' : prefersDark;
          if (dark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
    <!-- Inter — closest open-source substitute for Airbnb Cereal VF -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="SarkariNaukri" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <slot name="head" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z6B6KLQR10"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Z6B6KLQR10');
    </script>
  </head>
  <body class="font-sans text-ink bg-canvas-soft min-h-screen flex flex-col">
    <!-- Skip link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-ink focus:text-on-primary focus:rounded-sm focus:text-sm focus:font-medium focus:outline-none"
    >
      Skip to content
    </a>

    <Navbar />

    <div class="flex-1">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="border-t border-hairline bg-canvas">
      <div class="max-w-[1200px] mx-auto px-6 py-16">

        <!-- Top: logo + columns -->
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

          <!-- Brand column -->
          <div class="flex flex-col gap-3">
            <a href="/" class="text-sm font-semibold text-ink no-underline tracking-[-0.3px]">
              SarkariNaukriBoard
            </a>
            <p class="text-sm text-body leading-5 max-w-[200px]">
              India's trusted source for government, PSU, and private job listings.
            </p>
          </div>

          <!-- Link columns -->
          {footerColumns.map(col => (
            <div class="flex flex-col gap-3">
              <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-muted">
                {col.heading}
              </div>
              <ul class="flex flex-col gap-2 list-none m-0 p-0">
                {col.links.map(link => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-body no-underline hover:text-ink transition-colors"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <!-- Bottom bar -->
        <div class="mt-12 pt-6 border-t border-hairline flex flex-wrap items-center justify-between gap-4">
          <p class="text-xs text-muted m-0">
            © {new Date().getFullYear()} SarkariNaukriBoard. All rights reserved.
          </p>
          <div class="flex gap-4">
            <a href="/rss.xml" class="text-xs text-muted hover:text-ink transition-colors no-underline">RSS</a>
            <a href="/sitemap.xml" class="text-xs text-muted hover:text-ink transition-colors no-underline">Sitemap</a>
          </div>
        </div>

      </div>
    </footer>
  </body>
</html>
