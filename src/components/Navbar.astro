---
const pathname = Astro.url.pathname;
const search = Astro.url.searchParams;

const primaryLinks = [
  { label: 'Home',      href: '/',                exact: true },
  { label: 'Jobs',      href: '/jobs',             exact: true },
  { label: 'Govt Jobs', href: '/jobs?type=government', type: 'government' },
  { label: 'By State',  href: '/states' },
  { label: 'About',     href: '/about' },
];

const secondaryLinks = [
  { label: 'Private Jobs', href: '/jobs?type=private',   type: 'private' },
  { label: 'PSU Jobs',     href: '/jobs?type=psu',       type: 'psu' },
  { label: 'Freelance',    href: '/jobs?type=freelance',  type: 'freelance' },
  { label: 'Contact',      href: '/contact' },
];

function isActive(link: { href: string; exact?: boolean; type?: string }) {
  if (link.type) return pathname === '/jobs' && search.get('type') === link.type;
  if (link.exact) return pathname === link.href;
  return pathname.startsWith(link.href);
}
---

<style is:global>
  /* ── Nav root ── */
  #nav-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    font-family: Geist, Inter, system-ui, -apple-system, sans-serif;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  /* ── Logo ── */
  .nav-logo {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: -0.3px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .nav-logo:hover { opacity: 0.8; }

  /* ── Desktop link row ── */
  .nav-links {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  @media (min-width: 1024px) {
    .nav-links { display: flex; }
  }

  .nav-divider {
    width: 1px;
    height: 16px;
    background: var(--color-hairline);
    margin: 0 6px;
    flex-shrink: 0;
  }

  .nav-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 9999px;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--color-ink);
    background: var(--color-canvas-soft-2);
  }
  .nav-link.active {
    color: var(--color-ink);
    font-weight: 500;
    background: var(--color-canvas-soft-2);
  }

  /* ── Controls cluster ── */
  .nav-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Theme toggle — circular icon button */
  #theme-toggle {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-body);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  #theme-toggle:hover {
    background: var(--color-canvas-soft-2);
    color: var(--color-ink);
  }

  /* Hamburger */
  #hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: 6px;
    cursor: pointer;
    color: var(--color-body);
    transition: background 0.15s, color 0.15s;
  }
  #hamburger-btn:hover {
    background: var(--color-canvas-soft-2);
    color: var(--color-ink);
  }
  @media (min-width: 1024px) {
    #hamburger-btn { display: none; }
  }

  .hamburger-x { display: none; }
  #hamburger-btn.menu-open .hamburger-bars { display: none; }
  #hamburger-btn.menu-open .hamburger-x   { display: block; }

  /* ── Mobile menu ── */
  #mobile-menu {
    border-top: 1px solid var(--color-hairline);
    padding: 8px 24px 16px;
    background: var(--color-canvas);
  }

  .mobile-section-label {
    font-family: "Geist Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 12px 8px 4px;
  }

  .mobile-link {
    display: block;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    padding: 10px 8px;
    border-bottom: 1px solid var(--color-hairline);
    transition: color 0.15s;
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover  { color: var(--color-ink); }
  .mobile-link.active { color: var(--color-ink); font-weight: 500; }

  /* Sun/moon visibility */
  .icon-sun  { display: none; }
  .icon-moon { display: block; }
  html.dark .icon-sun  { display: block; }
  html.dark .icon-moon { display: none; }
</style>

<nav id="nav-root" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo">SarkariNaukriBoard</a>

    <div class="nav-links" role="list">
      {primaryLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link${isActive(link) ? ' active' : ''}`}
          aria-current={isActive(link) ? 'page' : undefined}
          role="listitem"
        >
          {link.label}
        </a>
      ))}
      <span class="nav-divider" aria-hidden="true"></span>
      {secondaryLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link${isActive(link) ? ' active' : ''}`}
          aria-current={isActive(link) ? 'page' : undefined}
          role="listitem"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="nav-controls">
      <button id="theme-toggle" aria-label="Toggle dark mode" type="button">
        <!-- Moon icon shown in light mode -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun icon shown in dark mode -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <button id="hamburger-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" type="button">
        <svg class="hamburger-bars" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="hamburger-x" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" hidden aria-label="Mobile navigation">
    <div class="mobile-section-label">Main</div>
    {primaryLinks.map(link => (
      <a
        href={link.href}
        class={`mobile-link${isActive(link) ? ' active' : ''}`}
        aria-current={isActive(link) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
    <div class="mobile-section-label">More</div>
    {secondaryLinks.map(link => (
      <a
        href={link.href}
        class={`mobile-link${isActive(link) ? ' active' : ''}`}
        aria-current={isActive(link) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const themeBtn   = document.getElementById('theme-toggle')!;
  const hamburger  = document.getElementById('hamburger-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // ── Theme toggle ──
  themeBtn.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // ── Mobile menu ──
  let menuOpen = false;

  function setMenuOpen(val: boolean) {
    menuOpen = val;
    mobileMenu.hidden = !val;
    hamburger.classList.toggle('menu-open', val);
    hamburger.setAttribute('aria-expanded', String(val));
    hamburger.setAttribute('aria-label', val ? 'Close menu' : 'Open menu');
    document.body.style.overflow = val ? 'hidden' : '';
  }

  hamburger.addEventListener('click', (e) => {
    e.stopPropagation();
    setMenuOpen(!menuOpen);
  });

  document.addEventListener('click', (e) => {
    if (menuOpen && !mobileMenu.contains(e.target as Node) && !hamburger.contains(e.target as Node)) {
      setMenuOpen(false);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) setMenuOpen(false);
  });
</script>
