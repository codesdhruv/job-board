---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/terms`;
---
<BaseLayout
  title="Terms & Conditions — SarkariNaukriBoard"
  description="Terms and conditions for using SarkariNaukriBoard."
  canonical={canonical}
>
  <main id="main-content" class="max-w-[720px] mx-auto px-6 py-16">
    <h1 class="text-balance text-[40px] font-semibold leading-[48px] tracking-[-1.6px] text-ink mb-6">
      Terms &amp; Conditions
    </h1>
    <p class="text-sm text-muted mb-8">Last updated: June 2026</p>
    <p class="text-base leading-7 text-body mb-4">
      By accessing SarkariNaukriBoard you agree to use this site for lawful purposes only. All job information published here is aggregated from official government notifications and public sources. We make no guarantee as to the accuracy, completeness, or timeliness of any listing. Always verify details with the official department or employer before applying.
    </p>
    <p class="text-base leading-7 text-body mb-4">
      SarkariNaukriBoard provides application links to external websites. We are not responsible for the content, availability, or practices of those external sites. Applying for a job through an external link is subject to the terms and conditions of that website.
    </p>
    <p class="text-base leading-7 text-body">
      We reserve the right to modify these terms at any time. Continued use of the site following any changes constitutes acceptance of the revised terms. For queries, use the <a href="/contact" class="text-link hover:underline">Contact</a> page.
    </p>
  </main>
</BaseLayout>
