---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/terms`;
---
<BaseLayout
  title="Terms & Conditions — SarkariNaukriBoard"
  description="Terms and conditions for using SarkariNaukriBoard."
  canonical={canonical}
>
  <main style="font-family:Geist,Inter,system-ui,-apple-system,sans-serif;color:#171717;background:#ffffff;">
    <div style="max-width:720px;margin:0 auto;padding:64px 24px;">
      <h1 style="font-size:40px;font-weight:600;line-height:48px;letter-spacing:-1.6px;margin:0 0 24px;">
        Terms &amp; Conditions
      </h1>
      <p style="font-size:14px;color:#888888;margin:0 0 32px;">Last updated: June 2026</p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        By accessing SarkariNaukriBoard you agree to use this site for lawful purposes only. All job information published here is aggregated from official government notifications and public sources. We make no guarantee as to the accuracy, completeness, or timeliness of any listing. Always verify details with the official department or employer before applying.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        SarkariNaukriBoard provides application links to external websites. We are not responsible for the content, availability, or practices of those external sites. Applying for a job through an external link is subject to the terms and conditions of that website.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0;">
        We reserve the right to modify these terms at any time. Continued use of the site following any changes constitutes acceptance of the revised terms. For queries, use the <a href="/contact" style="color:#0070f3;text-decoration:none;">Contact</a> page.
      </p>
    </div>
  </main>
</BaseLayout>
