---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../lib/db';

interface StateCountRow {
  name: string;
  slug: string;
  is_union_territory: number;
  job_count: number;
}

const db = getDb();
const { results } = await db
  .prepare(
    `SELECT s.name, s.slug, s.is_union_territory,
            COUNT(j.id) AS job_count
     FROM states s
     LEFT JOIN jobs j ON j.state_id = s.id
       AND j.is_published = 1
       AND j.last_date >= DATE('now')
     GROUP BY s.id
     ORDER BY s.is_union_territory, s.name`
  )
  .all<StateCountRow>();

const rows = results ?? [];
const allIndia = rows.find((r) => r.slug === 'all-india') ?? null;
const states = rows.filter((r) => r.is_union_territory === 0 && r.slug !== 'all-india');
const unionTerritories = rows.filter((r) => r.is_union_territory === 1);

const siteUrl = (env as any).SITE_URL ?? '';
const canonical = siteUrl ? `${siteUrl.replace(/\/$/, '')}/states` : undefined;
---
<BaseLayout
  title="Browse Jobs by State in India | SarkariNaukriBoard"
  description="Find government, PSU, and private sector jobs in your state. Browse all 36 states and union territories."
  canonical={canonical}
>
  <main style="max-width:960px;margin:0 auto;padding:24px 16px;font-family:system-ui,sans-serif;color:#171717;">
    <h1 style="font-size:32px;font-weight:600;letter-spacing:-1px;margin:0 0 8px;">Browse Jobs by State</h1>
    <p style="color:#4d4d4d;margin:0 0 24px;">Find government and private sector jobs in your state.</p>

    {allIndia && (
      <a
        href={`/state/${allIndia.slug}`}
        style="display:block;padding:16px;border:1px solid #ebebeb;border-radius:12px;background:#fafafa;color:#171717;text-decoration:none;margin-bottom:32px;"
      >
        <strong style="font-size:18px;">All India — Central Govt</strong>
        <span style="color:#4d4d4d;margin-left:8px;">({allIndia.job_count})</span>
      </a>
    )}

    <section style="margin-bottom:32px;">
      <h2 style="font-size:20px;font-weight:600;margin:0 0 12px;">States</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;">
        {states.map((s) => (
          <a
            href={`/state/${s.slug}`}
            aria-label={s.job_count === 0 ? `${s.name} — 0 active jobs` : undefined}
            style={`padding:10px 12px;border:1px solid #ebebeb;border-radius:8px;text-decoration:none;${s.job_count === 0 ? 'color:#888888;' : 'color:#171717;'}`}
          >
            {s.name} ({s.job_count})
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 style="font-size:20px;font-weight:600;margin:0 0 12px;">Union Territories</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;">
        {unionTerritories.map((s) => (
          <a
            href={`/state/${s.slug}`}
            aria-label={s.job_count === 0 ? `${s.name} — 0 active jobs` : undefined}
            style={`padding:10px 12px;border:1px solid #ebebeb;border-radius:8px;text-decoration:none;${s.job_count === 0 ? 'color:#888888;' : 'color:#171717;'}`}
          >
            {s.name} ({s.job_count})
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
