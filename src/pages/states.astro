---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../lib/db';

interface StateCountRow {
  name: string;
  slug: string;
  is_union_territory: number;
  job_count: number;
}

const db = getDb();
const { results } = await db
  .prepare(
    `SELECT s.name, s.slug, s.is_union_territory,
            COUNT(j.id) AS job_count
     FROM states s
     LEFT JOIN jobs j ON j.state_id = s.id
       AND j.is_published = 1
       AND j.last_date >= DATE('now')
     GROUP BY s.id
     ORDER BY s.is_union_territory, s.name`
  )
  .all<StateCountRow>();

const rows = results ?? [];
const allIndia = rows.find((r) => r.slug === 'all-india') ?? null;
const states = rows.filter((r) => r.is_union_territory === 0 && r.slug !== 'all-india');
const unionTerritories = rows.filter((r) => r.is_union_territory === 1);

const siteUrl = (env as any).SITE_URL ?? '';
const canonical = siteUrl ? `${siteUrl.replace(/\/$/, '')}/states` : undefined;
---
<BaseLayout
  title="Browse Jobs by State in India | SarkariNaukriBoard"
  description="Find government, PSU, and private sector jobs in your state. Browse all 36 states and union territories."
  canonical={canonical}
>
  <main id="main-content" class="max-w-[960px] mx-auto px-6 py-12">
    <h1 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink mb-2">
      Browse Jobs by State
    </h1>
    <p class="text-base text-body mb-8">Find government and private sector jobs in your state.</p>

    {allIndia && (
      <a
        href={`/state/${allIndia.slug}`}
        class="flex items-center justify-between p-5 bg-canvas-soft rounded-[14px] border border-hairline text-ink no-underline hover:border-hairline-strong hover:shadow-card transition-all mb-10"
      >
        <div>
          <span class="text-lg font-semibold">All India — Central Govt</span>
          <span class="text-body text-sm ml-2">Central government jobs across India</span>
        </div>
        <span class="text-sm text-muted shrink-0">{allIndia.job_count} jobs →</span>
      </a>
    )}

    <section class="mb-10">
      <h2 class="text-[20px] font-semibold leading-7 tracking-[-0.6px] text-ink mb-4">States</h2>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-2">
        {states.map((s) => (
          <a
            href={`/state/${s.slug}`}
            aria-label={s.job_count === 0 ? `${s.name} — 0 active jobs` : undefined}
            class={`block px-4 py-3 bg-canvas rounded-[14px] border border-hairline text-sm no-underline hover:border-hairline-strong hover:shadow-card transition-all ${s.job_count === 0 ? 'text-muted' : 'text-ink'}`}
          >
            <span class="font-medium">{s.name}</span>
            <span class="text-muted ml-1">({s.job_count})</span>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-[20px] font-semibold leading-7 tracking-[-0.6px] text-ink mb-4">Union Territories</h2>
      <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-2">
        {unionTerritories.map((s) => (
          <a
            href={`/state/${s.slug}`}
            aria-label={s.job_count === 0 ? `${s.name} — 0 active jobs` : undefined}
            class={`block px-4 py-3 bg-canvas rounded-[14px] border border-hairline text-sm no-underline hover:border-hairline-strong hover:shadow-card transition-all ${s.job_count === 0 ? 'text-muted' : 'text-ink'}`}
          >
            <span class="font-medium">{s.name}</span>
            <span class="text-muted ml-1">({s.job_count})</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
