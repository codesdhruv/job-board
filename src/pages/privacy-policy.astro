---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/privacy-policy`;
---
<BaseLayout
  title="Privacy Policy — SarkariNaukriBoard"
  description="Privacy policy for SarkariNaukriBoard. How we handle data, cookies and analytics."
  canonical={canonical}
>
  <main style="font-family:Geist,Inter,system-ui,-apple-system,sans-serif;color:#171717;background:#ffffff;">
    <div style="max-width:720px;margin:0 auto;padding:64px 24px;">
      <h1 style="font-size:40px;font-weight:600;line-height:48px;letter-spacing:-1.6px;margin:0 0 24px;">
        Privacy Policy
      </h1>
      <p style="font-size:14px;color:#888888;margin:0 0 32px;">Last updated: June 2026</p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        SarkariNaukriBoard does not collect personally identifiable information from visitors browsing public pages. Job listing data is sourced from public notifications and official department websites. No registration or account creation is required to search or view job listings.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        We may use standard server logs (IP address, browser user-agent, request path) for debugging and abuse prevention. These logs are retained for a limited period and are not shared with third parties. No third-party analytics or advertising scripts are loaded on this site.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0;">
        This policy may be updated as the site evolves. If you have questions or concerns, please contact us via the <a href="/contact" style="color:#0070f3;text-decoration:none;">Contact</a> page.
      </p>
    </div>
  </main>
</BaseLayout>
