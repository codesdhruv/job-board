---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/privacy-policy`;
---
<BaseLayout
  title="Privacy Policy — SarkariNaukriBoard"
  description="Privacy policy for SarkariNaukriBoard. How we handle data, cookies and analytics."
  canonical={canonical}
>
  <main id="main-content" class="max-w-[720px] mx-auto px-6 py-16">
    <h1 class="text-balance text-[40px] font-semibold leading-[48px] tracking-[-1.6px] text-ink mb-6">
      Privacy Policy
    </h1>
    <p class="text-sm text-muted mb-8">Last updated: June 2026</p>
    <p class="text-base leading-7 text-body mb-4">
      SarkariNaukriBoard does not collect personally identifiable information from visitors browsing public pages. Job listing data is sourced from public notifications and official department websites. No registration or account creation is required to search or view job listings.
    </p>
    <p class="text-base leading-7 text-body mb-4">
      We may use standard server logs (IP address, browser user-agent, request path) for debugging and abuse prevention. These logs are retained for a limited period and are not shared with third parties. No third-party analytics or advertising scripts are loaded on this site.
    </p>
    <p class="text-base leading-7 text-body">
      This policy may be updated as the site evolves. If you have questions or concerns, please contact us via the <a href="/contact" class="text-link hover:underline">Contact</a> page.
    </p>
  </main>
</BaseLayout>
