---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/about`;
---
<BaseLayout
  title="About SarkariNaukriBoard — India's job board for govt and private jobs"
  description="Learn about SarkariNaukriBoard — India's job board covering government, PSU, private and freelance roles with state-level filtering."
  canonical={canonical}
>
  <main style="font-family:Geist,Inter,system-ui,-apple-system,sans-serif;color:#171717;background:#ffffff;">
    <div style="max-width:720px;margin:0 auto;padding:64px 24px;">
      <h1 style="font-size:40px;font-weight:600;line-height:48px;letter-spacing:-1.6px;margin:0 0 24px;">
        About SarkariNaukriBoard
      </h1>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        SarkariNaukriBoard is India's dedicated job board for government, PSU/Semi-Government, private, and freelance/gig opportunities. Our mission is to make it easier for job seekers across every state and union territory to discover and apply for relevant openings — all in one place.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0 0 16px;">
        We focus on first-class state-level filtering, structured job data with Google Jobs rich results, and a clean mobile-first experience. Whether you are looking for a central government post or a private sector role in your home state, SarkariNaukriBoard keeps listings fresh and searchable.
      </p>
      <p style="font-size:16px;line-height:28px;color:#4d4d4d;margin:0;">
        This is a v1 independent project. Copy, corrections, and partnership inquiries are welcome — reach us at the <a href="/contact" style="color:#0070f3;text-decoration:none;">Contact</a> page.
      </p>
    </div>
  </main>
</BaseLayout>
