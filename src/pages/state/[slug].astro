---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JobCard from '../../components/JobCard.astro';
import { getDb } from '../../lib/db';
import { getListingCached } from '../../lib/kv';

const db = getDb();
const kv = (env as any).KV as KVNamespace;
const page = parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const { slug } = Astro.params;

const stateRow = await db
  .prepare(`SELECT id, name, slug FROM states WHERE slug = ?`)
  .bind(slug)
  .first<{ id: number; name: string; slug: string }>();

if (!stateRow) {
  return new Response(null, { status: 404 });
}

const results = await getListingCached<any[]>(
  kv,
  `jobs:state:${stateRow.slug}:p${page}`,
  () =>
    db
      .prepare(
        `SELECT j.*, jt.name AS type_name, jt.slug AS type_slug,
                c.name AS category_name, s.name AS state_name,
                s.slug AS state_slug, d.name AS dept_name, d.logo_r2_key
         FROM jobs j
         LEFT JOIN job_types jt ON j.job_type_id = jt.id
         LEFT JOIN categories c ON j.category_id = c.id
         LEFT JOIN states s ON j.state_id = s.id
         LEFT JOIN departments d ON j.department_id = d.id
         WHERE j.is_published = 1
           AND j.last_date >= DATE('now')
           AND s.slug = ?
         ORDER BY j.created_at DESC`
      )
      .bind(stateRow.slug)
      .all()
      .then((r) => r.results as any[]),
);

const count = results.length;

const tabs = [
  { label: 'All', href: `/state/${stateRow.slug}`, active: true },
  { label: 'Government', href: `/state/${stateRow.slug}/government`, active: false },
  { label: 'PSU / Semi-Govt', href: `/state/${stateRow.slug}/psu`, active: false },
  { label: 'Private', href: `/jobs?state=${stateRow.slug}&type=private`, active: false },
];

const title = `Jobs in ${stateRow.name} 2026 — Sarkari & Private`;
const description = `Find latest govt, PSU and private sector jobs in ${stateRow.name}. ${count} active vacancies.`;
const siteUrl = (env as any).SITE_URL ?? '';
const canonical = siteUrl ? `${siteUrl.replace(/\/$/, '')}/state/${stateRow.slug}` : undefined;
---
<BaseLayout title={title} description={description} canonical={canonical}>
  <main id="main-content" class="max-w-[1200px] mx-auto px-6 py-10">
    <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-body mb-8">
      <a href="/" class="text-link hover:underline">Home</a>
      <span class="text-muted" aria-hidden="true">›</span>
      <a href="/states" class="text-link hover:underline">States</a>
      <span class="text-muted" aria-hidden="true">›</span>
      <span class="text-ink">{stateRow.name}</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink mb-2">
        Jobs in {stateRow.name}
      </h1>
      <p class="text-base text-body">{count} active {count === 1 ? 'vacancy' : 'vacancies'} in {stateRow.name}</p>
    </div>

    <nav aria-label="Filter by job type" class="flex border-b border-hairline mb-8 overflow-x-auto">
      {tabs.map((t) => (
        <a
          href={t.href}
          aria-current={t.active ? 'page' : undefined}
          class={`px-4 py-3 text-sm whitespace-nowrap no-underline transition-colors shrink-0 ${
            t.active
              ? 'text-primary font-semibold border-b-2 border-primary -mb-px'
              : 'text-body hover:text-ink'
          }`}
        >
          {t.label}
        </a>
      ))}
    </nav>

    {count === 0 ? (
      <div class="bg-canvas-soft rounded-md p-12 text-center">
        <p class="text-body">No active jobs in {stateRow.name} right now. Check back soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
        {results.map((j: any) => <JobCard job={j} />)}
      </div>
    )}
  </main>
</BaseLayout>
