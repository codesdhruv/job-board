---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JobCard from '../../components/JobCard.astro';
import { getDb } from '../../lib/db';
import { getListingCached } from '../../lib/kv';

const db = getDb();
const kv = (env as any).KV as KVNamespace;
const page = parseInt(Astro.url.searchParams.get('page') ?? '1', 10);

const tabs = [
  { slug: null, label: 'All' },
  { slug: 'government', label: 'Government' },
  { slug: 'psu', label: 'PSU/Semi-Govt' },
  { slug: 'private', label: 'Private' },
  { slug: 'freelance', label: 'Freelance/Gig' },
];

const validTypeSlugs = tabs.map((t) => t.slug).filter((s): s is string => s !== null);
const typeParam = Astro.url.searchParams.get('type');
const activeType = typeParam && validTypeSlugs.includes(typeParam) ? typeParam : null;

const { results: stateRows } = await db
  .prepare(
    `SELECT id, name, slug, is_union_territory
     FROM states
     ORDER BY is_union_territory, name`
  )
  .all();

type StateRow = { id: number; name: string; slug: string; is_union_territory: number };
const allStates = stateRows as StateRow[];
const dropdownStates = allStates.filter((s) => s.slug !== 'all-india');
const validStateSlugs = new Set(allStates.map((s) => s.slug));

const stateParam = Astro.url.searchParams.get('state');
const activeState = stateParam && validStateSlugs.has(stateParam) ? stateParam : null;

const { results: categoryRows } = await db
  .prepare(`SELECT id, name, slug FROM categories ORDER BY name`)
  .all();
type CategoryRow = { id: number; name: string; slug: string };
const categories = categoryRows as CategoryRow[];
const validCategorySlugs = new Set(categories.map((c) => c.slug));

const categoryParam = Astro.url.searchParams.get('category');
const activeCategory = categoryParam && validCategorySlugs.has(categoryParam) ? categoryParam : null;

const qParam = Astro.url.searchParams.get('q') ?? '';
const qTrimmed = qParam.trim();
const activeQuery = qTrimmed.length >= 2 ? qTrimmed : null;

const where = ['j.is_published = 1', "j.last_date >= DATE('now')"];
const binds: string[] = [];
if (activeType) { where.push('jt.slug = ?'); binds.push(activeType); }
if (activeState) { where.push('s.slug = ?'); binds.push(activeState); }
if (activeCategory) { where.push('c.slug = ?'); binds.push(activeCategory); }
if (activeQuery) {
  where.push('(j.title LIKE ? OR d.name LIKE ?)');
  const like = `%${activeQuery}%`;
  binds.push(like, like);
}

const jobsSql = `SELECT j.*, jt.name AS type_name, jt.slug AS type_slug,
                        c.name AS category_name, s.name AS state_name,
                        s.slug AS state_slug, d.name AS dept_name, d.logo_r2_key
                 FROM jobs j
                 LEFT JOIN job_types jt ON j.job_type_id = jt.id
                 LEFT JOIN categories c ON j.category_id = c.id
                 LEFT JOIN states s ON j.state_id = s.id
                 LEFT JOIN departments d ON j.department_id = d.id
                 WHERE ${where.join(' AND ')}
                 ORDER BY j.created_at DESC`;

const jobsStmt = binds.length
  ? db.prepare(jobsSql).bind(...binds)
  : db.prepare(jobsSql);

function buildListingKey(): string {
  const parts = ['jobs'];
  if (activeState)    { parts.push('state',    activeState); }
  if (activeType)     { parts.push('type',      activeType); }
  if (activeCategory) { parts.push('category',  activeCategory); }
  if (!activeState && !activeType && !activeCategory) parts.push('all');
  parts.push(`p${page}`);
  return parts.join(':');
}

let results: any[];
if (activeQuery) {
  ({ results } = await jobsStmt.all());
} else {
  results = await getListingCached(kv, buildListingKey(), () =>
    jobsStmt.all().then((r) => r.results as any[])
  );
}

const countRows = await getListingCached<{ slug: string; count: number }[]>(
  kv,
  'counts:all',
  () =>
    db
      .prepare(
        `SELECT jt.slug AS slug, COUNT(*) AS count
         FROM jobs j
         JOIN job_types jt ON j.job_type_id = jt.id
         WHERE j.is_published = 1 AND j.last_date >= DATE('now')
         GROUP BY jt.slug`
      )
      .all()
      .then((r) => r.results as { slug: string; count: number }[]),
  600,
);

const counts = new Map<string | null, number>();
let total = 0;
for (const row of countRows as { slug: string; count: number }[]) {
  counts.set(row.slug, row.count);
  total += row.count;
}
counts.set(null, total);

function hrefFor(slug: string | null) {
  const p = new URLSearchParams(Astro.url.searchParams);
  p.delete('page');
  if (slug) p.set('type', slug);
  else p.delete('type');
  const qs = p.toString();
  return qs ? `/jobs?${qs}` : '/jobs';
}

const promoteState = activeType === 'government' || activeType === 'psu';

const preservedParams: { key: string; value: string }[] = [];
const preservedForCategory: { key: string; value: string }[] = [];
const preservedForSearch: { key: string; value: string }[] = [];
for (const [key, value] of Astro.url.searchParams.entries()) {
  if (key !== 'state' && key !== 'page') preservedParams.push({ key, value });
  if (key !== 'category' && key !== 'page') preservedForCategory.push({ key, value });
  if (key !== 'q' && key !== 'page') preservedForSearch.push({ key, value });
}

const states = dropdownStates.filter((s) => s.is_union_territory === 0);
const uts = dropdownStates.filter((s) => s.is_union_territory === 1);

const siteUrl = (env as any).SITE_URL ?? '';
const listingCanonical = siteUrl ? `${siteUrl.replace(/\/$/, '')}/jobs` : undefined;
const listingDescription = 'Browse government, PSU and private jobs in India. Filter by state, category and job type. Updated daily.';
---
<BaseLayout
  title="Browse Government & Private Jobs in India 2026 | SarkariNaukriBoard"
  description={listingDescription}
  canonical={listingCanonical}
>
  <main id="main-content" class="max-w-[1200px] mx-auto px-6 py-10">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink mb-2">
        Browse Jobs
      </h1>
      <p class="text-base text-body">Government, PSU, private and freelance jobs across India. Updated daily.</p>
    </div>

    <!-- Search -->
    <form method="get" action="/jobs" role="search" class="flex gap-2 mb-6 flex-wrap">
      {preservedForSearch.map((p) => <input type="hidden" name={p.key} value={p.value} />)}
      <input
        type="search"
        name="q"
        value={qTrimmed}
        minlength="2"
        placeholder="Search jobs by title, department…"
        aria-label="Search jobs"
        autocomplete="off"
        class="flex-[1_1_280px] h-10 px-3 font-sans text-sm text-ink bg-canvas border border-hairline rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:border-transparent transition-shadow"
      />
      <button
        type="submit"
        class="h-10 px-5 font-sans text-sm font-medium text-on-primary bg-ink border-none rounded-sm cursor-pointer hover:bg-[#2e2e2e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 transition-colors"
      >
        Search
      </button>
    </form>

    <!-- Filters row -->
    <div class="flex flex-wrap gap-3 mb-6">
      {/* State filter — promoted for govt/psu, otherwise compact */}
      <form method="get" action="/jobs">
        {preservedParams.map((p) => <input type="hidden" name={p.key} value={p.value} />)}
        {promoteState && (
          <label for="state-select" class="block text-sm font-medium text-ink mb-1">State</label>
        )}
        <select
          id="state-select"
          name="state"
          aria-label="Filter by state"
          onchange="this.form.submit()"
          class="h-10 px-3 border border-hairline rounded-sm bg-canvas text-ink text-sm outline-none focus-visible:ring-2 focus-visible:ring-ink cursor-pointer"
        >
          <option value="" selected={!activeState}>All India</option>
          <optgroup label="States">
            {states.map((s) => (
              <option value={s.slug} selected={activeState === s.slug}>{s.name}</option>
            ))}
          </optgroup>
          <optgroup label="Union Territories">
            {uts.map((s) => (
              <option value={s.slug} selected={activeState === s.slug}>{s.name}</option>
            ))}
          </optgroup>
        </select>
      </form>

      {/* Category filter */}
      <form method="get" action="/jobs">
        {preservedForCategory.map((p) => <input type="hidden" name={p.key} value={p.value} />)}
        <select
          name="category"
          aria-label="Filter by category"
          onchange="this.form.submit()"
          class="h-10 px-3 border border-hairline rounded-sm bg-canvas text-ink text-sm outline-none focus-visible:ring-2 focus-visible:ring-ink cursor-pointer"
        >
          <option value="" selected={!activeCategory}>All categories</option>
          {categories.map((c) => (
            <option value={c.slug} selected={activeCategory === c.slug}>{c.name}</option>
          ))}
        </select>
      </form>
    </div>

    <!-- Job type tabs -->
    <nav aria-label="Filter by job type" class="flex border-b border-hairline mb-8 overflow-x-auto">
      {tabs.map((t) => {
        const isActive = activeType === t.slug;
        const count = counts.get(t.slug) ?? 0;
        return (
          <a
            href={hrefFor(t.slug)}
            aria-current={isActive ? 'page' : undefined}
            class={`px-4 py-3 text-sm whitespace-nowrap no-underline transition-colors shrink-0 ${
              isActive
                ? 'text-ink font-semibold border-b-2 border-ink -mb-px'
                : 'text-body hover:text-ink'
            }`}
          >
            {t.label} <span class="text-muted">({count})</span>
          </a>
        );
      })}
    </nav>

    <!-- Results -->
    {results.length === 0 ? (
      <div class="bg-canvas-soft rounded-md p-12 text-center">
        <p class="text-body mb-4">No jobs found matching your filters.</p>
        <a href="/jobs" class="text-sm text-link hover:underline">Clear all filters</a>
      </div>
    ) : (
      <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
        {results.map((j: any) => <JobCard job={j} />)}
      </div>
    )}

  </main>
</BaseLayout>
