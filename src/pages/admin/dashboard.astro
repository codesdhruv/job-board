---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';

const db = getDb();

const [liveRes, expiringRes, draftRes, expiredRes, expiringRows, recentRows] =
  await Promise.all([
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date >= DATE('now')")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date BETWEEN DATE('now') AND DATE('now', '+7 days')")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 0")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE last_date < DATE('now')")
      .first<{ n: number }>(),
    db.prepare(`
      SELECT j.id, j.slug, j.title, j.last_date, d.name AS dept_name
      FROM jobs j
      LEFT JOIN departments d ON j.department_id = d.id
      WHERE j.is_published = 1
        AND j.last_date BETWEEN DATE('now') AND DATE('now', '+7 days')
      ORDER BY j.last_date ASC
    `).all<{ id: number; slug: string; title: string; last_date: string; dept_name: string | null }>(),
    db.prepare(`
      SELECT j.id, j.slug, j.title, j.created_at,
             jt.name AS type_name, s.name AS state_name
      FROM jobs j
      LEFT JOIN job_types jt ON j.job_type_id = jt.id
      LEFT JOIN states s ON j.state_id = s.id
      ORDER BY j.created_at DESC
      LIMIT 5
    `).all<{ id: number; slug: string; title: string; created_at: string; type_name: string | null; state_name: string | null }>(),
  ]);

const liveCount     = liveRes?.n     ?? 0;
const expiringCount = expiringRes?.n  ?? 0;
const draftCount    = draftRes?.n     ?? 0;
const expiredCount  = expiredRes?.n   ?? 0;

function formatDate(dateStr: string): string {
  // Handle both "YYYY-MM-DD" and "YYYY-MM-DD HH:MM:SS" (D1 datetime) formats
  const normalized = dateStr.includes('T') || dateStr.includes(' ')
    ? dateStr.replace(' ', 'T')
    : dateStr + 'T00:00:00';
  return new Date(normalized).toLocaleDateString('en-IN', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
}

const metrics = [
  { label: 'Total live jobs',      value: liveCount,     accent: '#0070f3' },
  { label: 'Expiring in 7 days',   value: expiringCount, accent: '#f5a623' },
  { label: 'Drafts',               value: draftCount,    accent: '#888888' },
  { label: 'Expired',              value: expiredCount,  accent: '#ee0000' },
];
---
<AdminLayout title="Dashboard — SarkariNaukriBoard">
  <h1 style="font-size:22px;font-weight:600;letter-spacing:-0.4px;color:#171717;margin:0 0 28px;">Dashboard</h1>

  <!-- Metric cards -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px;">
    {metrics.map(m => (
      <div style={`background:#fff;border:1px solid #ebebeb;border-radius:8px;padding:20px 24px;`}>
        <div style="font-size:13px;color:#888888;margin-bottom:8px;">{m.label}</div>
        <div style={`font-size:32px;font-weight:600;letter-spacing:-1px;color:${m.accent};`}>{m.value}</div>
      </div>
    ))}
  </div>

  <!-- Expiring soon -->
  <section style="margin-bottom:40px;">
    <h2 style="font-size:16px;font-weight:600;color:#171717;margin:0 0 14px;">Expiring soon</h2>
    {expiringRows.results.length === 0 ? (
      <p style="font-size:14px;color:#888888;">No jobs expiring in the next 7 days.</p>
    ) : (
      <div style="background:#fff;border:1px solid #ebebeb;border-radius:8px;overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr style="background:#fafafa;border-bottom:1px solid #ebebeb;">
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Title</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Department</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Last date</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {expiringRows.results.map((row, i) => (
              <tr style={i % 2 === 1 ? 'background:#fafafa;' : ''}>
                <td style="padding:10px 16px;color:#171717;">{row.title}</td>
                <td style="padding:10px 16px;color:#4d4d4d;">{row.dept_name ?? '—'}</td>
                <td style="padding:10px 16px;color:#ee0000;font-weight:500;">{formatDate(row.last_date)}</td>
                <td style="padding:10px 16px;">
                  <a href={`/admin/jobs/${row.id}/edit`} style="color:#0070f3;text-decoration:none;margin-right:12px;">Edit</a>
                  <a href={`/admin/jobs/${row.id}/delete`} style="color:#ee0000;text-decoration:none;">Delete</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <!-- Recently added -->
  <section>
    <h2 style="font-size:16px;font-weight:600;color:#171717;margin:0 0 14px;">Recently added</h2>
    {recentRows.results.length === 0 ? (
      <p style="font-size:14px;color:#888888;">No jobs yet.</p>
    ) : (
      <div style="background:#fff;border:1px solid #ebebeb;border-radius:8px;overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr style="background:#fafafa;border-bottom:1px solid #ebebeb;">
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Title</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Type</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">State</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Posted</th>
              <th style="text-align:left;padding:10px 16px;font-weight:600;color:#171717;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {recentRows.results.map((row, i) => (
              <tr style={i % 2 === 1 ? 'background:#fafafa;' : ''}>
                <td style="padding:10px 16px;color:#171717;">{row.title}</td>
                <td style="padding:10px 16px;color:#4d4d4d;">{row.type_name ?? '—'}</td>
                <td style="padding:10px 16px;color:#4d4d4d;">{row.state_name ?? '—'}</td>
                <td style="padding:10px 16px;color:#888888;">{formatDate(row.created_at)}</td>
                <td style="padding:10px 16px;">
                  <a href={`/admin/jobs/${row.id}/edit`} style="color:#0070f3;text-decoration:none;margin-right:12px;">Edit</a>
                  <a href={`/admin/jobs/${row.id}/delete`} style="color:#ee0000;text-decoration:none;">Delete</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>
