---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';

const db = getDb();

const [liveRes, expiringRes, draftRes, expiredRes, expiringRows, recentRows] =
  await Promise.all([
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date >= DATE('now')")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date BETWEEN DATE('now') AND DATE('now', '+7 days')")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE is_published = 0")
      .first<{ n: number }>(),
    db.prepare("SELECT COUNT(*) AS n FROM jobs WHERE last_date < DATE('now')")
      .first<{ n: number }>(),
    db.prepare(`
      SELECT j.id, j.slug, j.title, j.last_date, d.name AS dept_name
      FROM jobs j
      LEFT JOIN departments d ON j.department_id = d.id
      WHERE j.is_published = 1
        AND j.last_date BETWEEN DATE('now') AND DATE('now', '+7 days')
      ORDER BY j.last_date ASC
    `).all<{ id: number; slug: string; title: string; last_date: string; dept_name: string | null }>(),
    db.prepare(`
      SELECT j.id, j.slug, j.title, j.created_at,
             jt.name AS type_name, s.name AS state_name
      FROM jobs j
      LEFT JOIN job_types jt ON j.job_type_id = jt.id
      LEFT JOIN states s ON j.state_id = s.id
      ORDER BY j.created_at DESC
      LIMIT 5
    `).all<{ id: number; slug: string; title: string; created_at: string; type_name: string | null; state_name: string | null }>(),
  ]);

const liveCount     = liveRes?.n     ?? 0;
const expiringCount = expiringRes?.n  ?? 0;
const draftCount    = draftRes?.n     ?? 0;
const expiredCount  = expiredRes?.n   ?? 0;

function formatDate(dateStr: string): string {
  const normalized = dateStr.includes('T') || dateStr.includes(' ')
    ? dateStr.replace(' ', 'T')
    : dateStr + 'T00:00:00';
  return new Date(normalized).toLocaleDateString('en-IN', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
}

const metrics = [
  { label: 'Total Live Jobs',    value: liveCount,     accent: '#0070f3' },
  { label: 'Expiring in 7 Days', value: expiringCount, accent: '#f5a623' },
  { label: 'Drafts',             value: draftCount,    accent: '#888888' },
  { label: 'Expired',            value: expiredCount,  accent: '#ee0000' },
];

const thStyle = 'text-align:left;padding:10px 16px;font-size:11px;font-weight:500;color:var(--c-muted);text-transform:uppercase;letter-spacing:0.06em;font-family:"Geist Mono",ui-monospace,monospace;background:var(--c-canvas-soft-2);border-bottom:1px solid var(--c-hairline);';
const tdStyle = 'padding:12px 16px;font-size:14px;color:var(--c-ink);border-bottom:1px solid var(--c-hairline);';
---
<AdminLayout title="Dashboard — SarkariNaukriBoard">
  <style>
    @media (max-width: 768px) {
      .metrics-grid { grid-template-columns: 1fr 1fr !important; }
    }
    @media (max-width: 480px) {
      .metrics-grid { grid-template-columns: 1fr !important; }
    }
  </style>
  <h1 style="font-size:20px;font-weight:600;letter-spacing:-0.6px;color:var(--c-ink);margin:0 0 28px;">Dashboard</h1>

  <!-- Metric cards -->
  <div class="metrics-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:48px;">
    {metrics.map(m => (
      <div style="background:var(--c-canvas);border-radius:8px;padding:20px 24px;box-shadow:var(--shadow-card);">
        <div style="font-size:12px;font-weight:400;color:var(--c-muted);margin-bottom:10px;">{m.label}</div>
        <div style={`font-size:32px;font-weight:600;letter-spacing:-1px;color:${m.accent};`}>{m.value}</div>
      </div>
    ))}
  </div>

  <!-- Expiring soon -->
  <section style="margin-bottom:48px;">
    <h2 style="font-size:12px;font-weight:500;color:var(--c-muted);text-transform:uppercase;letter-spacing:0.06em;font-family:'Geist Mono',ui-monospace,monospace;margin:0 0 14px;">Expiring Soon</h2>
    {expiringRows.results.length === 0 ? (
      <p style="font-size:14px;color:var(--c-muted);">No jobs expiring in the next 7 days.</p>
    ) : (
      <div style="background:var(--c-canvas);border-radius:8px;overflow:hidden;box-shadow:var(--shadow-card-simple);">
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:14px;">
            <thead>
              <tr>
                <th style={thStyle}>Title</th>
                <th style={thStyle}>Department</th>
                <th style={thStyle}>Last Date</th>
                <th style={thStyle}>Actions</th>
              </tr>
            </thead>
            <tbody>
              {expiringRows.results.map(row => (
                <tr>
                  <td style={tdStyle}>{row.title}</td>
                  <td style={`${tdStyle}color:var(--c-body);`}>{row.dept_name ?? '—'}</td>
                  <td style={`${tdStyle}color:var(--c-error);font-weight:500;`}>{formatDate(row.last_date)}</td>
                  <td style={tdStyle}>
                    <a href={`/admin/jobs/${row.id}/edit`} style="color:var(--c-link);text-decoration:none;margin-right:12px;">Edit</a>
                    <a href={`/admin/jobs/${row.id}/delete`} style="color:var(--c-error);text-decoration:none;">Delete</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}
  </section>

  <!-- Recently added -->
  <section>
    <h2 style="font-size:12px;font-weight:500;color:var(--c-muted);text-transform:uppercase;letter-spacing:0.06em;font-family:'Geist Mono',ui-monospace,monospace;margin:0 0 14px;">Recently Added</h2>
    {recentRows.results.length === 0 ? (
      <p style="font-size:14px;color:var(--c-muted);">No jobs yet.</p>
    ) : (
      <div style="background:var(--c-canvas);border-radius:8px;overflow:hidden;box-shadow:var(--shadow-card-simple);">
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:14px;">
            <thead>
              <tr>
                <th style={thStyle}>Title</th>
                <th style={thStyle}>Type</th>
                <th style={thStyle}>State</th>
                <th style={thStyle}>Posted</th>
                <th style={thStyle}>Actions</th>
              </tr>
            </thead>
            <tbody>
              {recentRows.results.map(row => (
                <tr>
                  <td style={tdStyle}>{row.title}</td>
                  <td style={`${tdStyle}color:var(--c-body);`}>{row.type_name ?? '—'}</td>
                  <td style={`${tdStyle}color:var(--c-body);`}>{row.state_name ?? '—'}</td>
                  <td style={`${tdStyle}color:var(--c-muted);`}>{formatDate(row.created_at)}</td>
                  <td style={tdStyle}>
                    <a href={`/admin/jobs/${row.id}/edit`} style="color:var(--c-link);text-decoration:none;margin-right:12px;">Edit</a>
                    <a href={`/admin/jobs/${row.id}/delete`} style="color:var(--c-error);text-decoration:none;">Delete</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}
  </section>
</AdminLayout>
