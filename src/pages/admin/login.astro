---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb, type AdminRow } from '../../lib/db';
import { verifyPassword, verifySession, signSession } from '../../lib/auth';

const secret = (env as any).ADMIN_SECRET as string | undefined;
if (!secret) throw new Error('ADMIN_SECRET is not configured');

// Already-logged-in short-circuit
const existing = Astro.cookies.get('admin_session');
if (existing) {
  const payload = await verifySession(existing.value, secret);
  if (payload) return Astro.redirect('/admin/dashboard');
}

let error: string | null = null;
let submittedUsername = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const username = String(form.get('username') ?? '').trim();
  const password = String(form.get('password') ?? '');
  submittedUsername = username;

  if (!username || !password) {
    error = 'Invalid username or password';
  } else {
    const db = getDb();
    const row = await db
      .prepare('SELECT id, username, password_hash FROM admins WHERE username = ? LIMIT 1')
      .bind(username)
      .first<Pick<AdminRow, 'id' | 'username' | 'password_hash'>>();

    if (!row || !(await verifyPassword(password, row.password_hash))) {
      error = 'Invalid username or password';
    } else {
      const expiresAt = Date.now() + 8 * 60 * 60 * 1000;
      const token = await signSession(
        { adminId: row.id, username: row.username, expiresAt },
        secret,
      );
      Astro.cookies.set('admin_session', token, {
        httpOnly: true,
        secure: true,
        sameSite: 'strict',
        path: '/',
        expires: new Date(expiresAt),
      });
      return Astro.redirect('/admin/dashboard');
    }
  }
}
---
<AdminLayout title="Admin Login — SarkariNaukriBoard">
  <main style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:var(--page-bg);">
    <div style="width:100%;max-width:380px;background:var(--c-canvas);border:1px solid var(--c-hairline);border-radius:12px;padding:40px;box-shadow:var(--shadow-card);">
      <h1 style="font-size:24px;font-weight:600;letter-spacing:-0.96px;margin:0 0 6px;color:var(--c-ink);">Admin Login</h1>
      <p style="font-size:14px;color:var(--c-muted);margin:0 0 28px;">Sign in to manage jobs.</p>
      {error && (
        <p role="alert" style="background:var(--c-error-soft);border:1px solid var(--c-error);color:var(--c-error);padding:10px 12px;border-radius:6px;margin:0 0 20px;font-size:14px;">{error}</p>
      )}
      <form method="POST" autocomplete="off">
        <label style="display:block;font-size:13px;font-weight:500;color:var(--c-body);margin-bottom:6px;">Username</label>
        <input name="username" type="text" required autofocus value={submittedUsername}
          style="width:100%;height:40px;padding:0 12px;border:1px solid var(--c-hairline);border-radius:6px;margin-bottom:16px;font-size:14px;color:var(--c-ink);box-sizing:border-box;font-family:inherit;background:var(--c-canvas);" />
        <label style="display:block;font-size:13px;font-weight:500;color:var(--c-body);margin-bottom:6px;">Password</label>
        <input name="password" type="password" required
          style="width:100%;height:40px;padding:0 12px;border:1px solid var(--c-hairline);border-radius:6px;margin-bottom:24px;font-size:14px;color:var(--c-ink);box-sizing:border-box;font-family:inherit;background:var(--c-canvas);" />
        <button type="submit" style="width:100%;height:40px;padding:0 16px;background:#171717;color:#ffffff;border:0;border-radius:6px;font-weight:500;font-size:14px;cursor:pointer;font-family:inherit;">Log In</button>
      </form>
    </div>
  </main>
</AdminLayout>
