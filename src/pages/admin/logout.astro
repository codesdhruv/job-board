---
if (Astro.request.method !== 'POST') {
  return new Response('Method Not Allowed', {
    status: 405,
    headers: { Allow: 'POST' },
  });
}

return new Response(null, {
  status: 302,
  headers: {
    Location: '/admin/login',
    'Set-Cookie': 'admin_session=; Path=/; HttpOnly; SameSite=Lax; Max-Age=0',
  },
});
---
