---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb } from '../../../lib/db';

const db = getDb();

const url = new URL(Astro.request.url);
const pageParam = parseInt(url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageParam) && pageParam >= 1 ? pageParam : 1;
const pageSize = 50;
const offset = (page - 1) * pageSize;

const flash = url.searchParams.get('success') === '1'
  ? 'Job posted successfully.'
  : url.searchParams.get('updated') === '1'
    ? 'Job updated.'
    : url.searchParams.get('deleted') === '1'
      ? 'Job deleted.'
      : null;

const [countRes, rowsRes] = await Promise.all([
  db.prepare('SELECT COUNT(*) AS n FROM jobs').first<{ n: number }>(),
  db.prepare(`
    SELECT j.id, j.title, j.last_date, j.is_published,
           jt.name AS type_name,
           s.name AS state_name
    FROM jobs j
    LEFT JOIN job_types jt ON j.job_type_id = jt.id
    LEFT JOIN states s ON j.state_id = s.id
    ORDER BY j.created_at DESC
    LIMIT ? OFFSET ?
  `).bind(pageSize, offset).all<{
    id: number;
    title: string;
    last_date: string;
    is_published: number;
    type_name: string | null;
    state_name: string | null;
  }>(),
]);

const total = countRes?.n ?? 0;
const totalPages = Math.max(1, Math.ceil(total / pageSize));
const rows = rowsRes.results;
const today = new Date().toISOString().slice(0, 10);

function formatDate(dateStr: string): string {
  const normalized = dateStr.includes('T') || dateStr.includes(' ')
    ? dateStr.replace(' ', 'T')
    : dateStr + 'T00:00:00';
  return new Date(normalized).toLocaleDateString('en-IN', {
    day: 'numeric', month: 'short', year: 'numeric',
  });
}

function statusBadge(row: { is_published: number; last_date: string }): { label: string; bg: string; color: string } {
  if (row.is_published === 0) return { label: 'Draft',   bg: '#ffefcf', color: '#ab570a' };
  if (row.last_date.slice(0, 10) < today) return { label: 'Expired', bg: '#f7d4d6', color: '#c50000' };
  return { label: 'Live', bg: '#dcfce7', color: '#15803d' };
}

const windowSize = 5;
let pageStart = Math.max(1, page - Math.floor(windowSize / 2));
let pageEnd = Math.min(totalPages, pageStart + windowSize - 1);
pageStart = Math.max(1, pageEnd - windowSize + 1);
const pageNumbers: number[] = [];
for (let i = pageStart; i <= pageEnd; i++) pageNumbers.push(i);

const thStyle = 'text-align:left;padding:10px 16px;font-size:11px;font-weight:500;color:#888888;text-transform:uppercase;letter-spacing:0.06em;font-family:"Geist Mono",ui-monospace,monospace;background:#fafafa;border-bottom:1px solid #ebebeb;';
const tdStyle = 'padding:12px 16px;font-size:14px;color:#171717;border-bottom:1px solid #ebebeb;';
---
<AdminLayout title="All Jobs — SarkariNaukriBoard">
  <div style="display:flex;justify-content:space-between;align-items:center;margin:0 0 24px;">
    <h1 style="font-size:20px;font-weight:600;letter-spacing:-0.6px;color:#171717;margin:0;">All Jobs</h1>
    <a href="/admin/jobs/new" style="display:inline-flex;align-items:center;background:#171717;color:#ffffff;text-decoration:none;font-size:14px;font-weight:500;padding:0 14px;height:36px;border-radius:6px;">+ Add New Job</a>
  </div>

  {flash && (
    <div style="display:flex;align-items:center;gap:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-left:3px solid #22a565;color:#15803d;padding:10px 14px;border-radius:6px;font-size:14px;margin-bottom:20px;">
      ✓ {flash}
    </div>
  )}

  {rows.length === 0 ? (
    <div style="background:#ffffff;border-radius:8px;padding:48px 24px;text-align:center;box-shadow:inset 0 0 0 1px #00000014;">
      <p style="font-size:14px;color:#888888;margin:0;">No jobs yet. Click <strong>+ Add New Job</strong> to create one.</p>
    </div>
  ) : (
    <div style="background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:inset 0 0 0 1px #00000014;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:14px;">
          <thead>
            <tr>
              <th style={thStyle}>ID</th>
              <th style={thStyle}>Title</th>
              <th style={thStyle}>Type</th>
              <th style={thStyle}>State</th>
              <th style={thStyle}>Last Date</th>
              <th style={thStyle}>Status</th>
              <th style={thStyle}>Edit</th>
              <th style={thStyle}>Delete</th>
            </tr>
          </thead>
          <tbody>
            {rows.map(row => {
              const s = statusBadge(row);
              return (
                <tr>
                  <td style={`${tdStyle}color:#888888;`}>{row.id}</td>
                  <td style={tdStyle}>{row.title}</td>
                  <td style={`${tdStyle}color:#4d4d4d;`}>{row.type_name ?? '—'}</td>
                  <td style={`${tdStyle}color:#4d4d4d;`}>{row.state_name ?? '—'}</td>
                  <td style={`${tdStyle}color:#4d4d4d;`}>{formatDate(row.last_date)}</td>
                  <td style={tdStyle}>
                    <span style={`display:inline-block;padding:2px 8px;border-radius:9999px;font-size:12px;font-weight:500;background:${s.bg};color:${s.color};`}>{s.label}</span>
                  </td>
                  <td style={tdStyle}>
                    <a href={`/admin/jobs/${row.id}/edit`} style="color:#0070f3;text-decoration:none;">Edit</a>
                  </td>
                  <td style={tdStyle}>
                    <form method="POST" action={`/admin/jobs/${row.id}/delete`} onsubmit="return confirm('Delete this job?')" style="display:inline;margin:0;">
                      <button type="submit" style="background:none;border:none;color:#ee0000;cursor:pointer;font:inherit;padding:0;">Delete</button>
                    </form>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  {totalPages > 1 && (
    <div style="display:flex;justify-content:center;align-items:center;gap:6px;margin-top:28px;font-size:14px;">
      {page > 1 ? (
        <a href={`/admin/jobs?page=${page - 1}`} style="color:#171717;text-decoration:none;padding:0 10px;height:32px;display:inline-flex;align-items:center;border:1px solid #ebebeb;border-radius:6px;">← Prev</a>
      ) : (
        <span style="color:#ebebeb;padding:0 10px;height:32px;display:inline-flex;align-items:center;border:1px solid #ebebeb;border-radius:6px;">← Prev</span>
      )}
      {pageNumbers.map(n => (
        n === page ? (
          <span style="font-weight:600;color:#171717;padding:0 10px;height:32px;display:inline-flex;align-items:center;background:#f5f5f5;border:1px solid #ebebeb;border-radius:6px;">{n}</span>
        ) : (
          <a href={`/admin/jobs?page=${n}`} style="color:#171717;text-decoration:none;padding:0 10px;height:32px;display:inline-flex;align-items:center;border:1px solid #ebebeb;border-radius:6px;">{n}</a>
        )
      ))}
      {page < totalPages ? (
        <a href={`/admin/jobs?page=${page + 1}`} style="color:#171717;text-decoration:none;padding:0 10px;height:32px;display:inline-flex;align-items:center;border:1px solid #ebebeb;border-radius:6px;">Next →</a>
      ) : (
        <span style="color:#ebebeb;padding:0 10px;height:32px;display:inline-flex;align-items:center;border:1px solid #ebebeb;border-radius:6px;">Next →</span>
      )}
    </div>
  )}
</AdminLayout>
