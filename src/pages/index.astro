---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import JobCard from '../components/JobCard.astro';
import { getDb } from '../lib/db';

const db = getDb();

const jobTypes = [
  { slug: 'government', name: 'Government',     icon: '🏛️' },
  { slug: 'psu',        name: 'PSU / Semi-Govt', icon: '🏗️' },
  { slug: 'private',    name: 'Private',         icon: '🏢' },
  { slug: 'freelance',  name: 'Freelance / Gig', icon: '💼' },
];

const [totalRes, typeCountsRes, latestRes, featuredStatesRes, categoriesRes] = await Promise.all([
  db
    .prepare(`SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date >= DATE('now')`)
    .first<{ n: number }>(),
  db
    .prepare(
      `SELECT jt.slug AS slug, COUNT(*) AS count
       FROM jobs j JOIN job_types jt ON j.job_type_id = jt.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       GROUP BY jt.slug`
    )
    .all(),
  db
    .prepare(
      `SELECT j.id, j.slug, j.title, j.last_date, j.vacancies, j.salary,
              jt.name AS type_name, jt.slug AS type_slug,
              s.name AS state_name, d.name AS dept_name
       FROM jobs j
       LEFT JOIN job_types jt ON j.job_type_id = jt.id
       LEFT JOIN states s ON j.state_id = s.id
       LEFT JOIN departments d ON j.department_id = d.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       ORDER BY j.created_at DESC LIMIT 10`
    )
    .all(),
  db
    .prepare(
      `SELECT s.name, s.slug, COUNT(j.id) AS count
       FROM states s JOIN jobs j ON j.state_id = s.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       GROUP BY s.id ORDER BY count DESC LIMIT 8`
    )
    .all(),
  db.prepare(`SELECT name, slug FROM categories ORDER BY name`).all(),
]);

const totalCount = totalRes?.n ?? 0;

const typeCountMap = new Map<string, number>(
  (typeCountsRes.results as { slug: string; count: number }[]).map((r) => [r.slug, r.count])
);

const latestJobs = latestRes.results as Array<{
  id: number; slug: string; title: string; last_date: string;
  vacancies: number | null; salary: string | null;
  type_name: string | null; type_slug: string | null;
  state_name: string | null; dept_name: string | null;
}>;

const featuredStates = featuredStatesRes.results as Array<{ name: string; slug: string; count: number }>;
const categories = categoriesRes.results as Array<{ name: string; slug: string }>;

const quickLinks = [
  { label: 'UPSC',     href: '/jobs?q=UPSC' },
  { label: 'SSC',      href: '/jobs?q=SSC' },
  { label: 'Railways', href: '/category/railways' },
  { label: 'Banking',  href: '/category/banking' },
  { label: 'Defence',  href: '/category/defence' },
];

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/`;
---
<BaseLayout
  title="SarkariNaukriBoard — Government & Private Jobs in India 2026"
  description="Find latest government, PSU and private sector jobs across India. Browse by state, category and job type. Updated daily."
  canonical={canonical}
>
  <main id="main-content">

    <!-- Hero -->
    <section class="bg-canvas border-b border-hairline py-16 sm:py-20 px-6 text-center">
      <div class="max-w-[680px] mx-auto">
        <h1 class="text-[28px] font-bold leading-[1.43] text-ink mb-2 [text-wrap:balance]">
          Find Your Dream Government Job
        </h1>
        <p class="text-base text-muted mb-7">
          Browse {totalCount} sarkari and private jobs across India.
        </p>

        <form action="/jobs" method="get" role="search" class="search-pill max-w-[560px] mx-auto mb-5">
          <input
            type="search"
            name="q"
            placeholder="Search jobs by title, department…"
            aria-label="Search jobs"
            autocomplete="off"
          />
          <button type="submit" class="search-orb" aria-label="Search">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10.5 3a7.5 7.5 0 1 1 0 15 7.5 7.5 0 0 1 0-15zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11zm8.47 10.56 1.41 1.41-1.41 1.42-1.42-1.42a1 1 0 1 1 1.42-1.41z"/>
            </svg>
          </button>
        </form>

        <div class="flex gap-2 flex-wrap justify-center">
          {quickLinks.map((q) => (
            <a href={q.href} class="quick-link">{q.label}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- Job-type cards -->
    <section class="py-8 px-6 max-w-[1200px] mx-auto">
      <h2 class="text-[22px] font-semibold leading-[1.18] tracking-[-0.44px] text-ink mb-4 [text-wrap:balance]">
        Browse by Job Type
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-3 sm:gap-4">
        {jobTypes.map((t) => (
          <a
            href={`/jobs?type=${t.slug}`}
            class="block p-4 sm:p-6 bg-canvas rounded-[14px] border border-hairline no-underline text-ink hover:border-hairline-strong hover:shadow-card transition-[border-color,box-shadow] focus-visible:ring-2 focus-visible:ring-ink focus-visible:outline-none"
          >
            <span class="text-2xl sm:text-3xl mb-2 sm:mb-3 block" aria-hidden="true">{t.icon}</span>
            <div class="text-sm sm:text-base font-semibold leading-6 text-ink truncate">{t.name}</div>
            <div class="text-xs sm:text-sm text-muted mt-0.5 sm:mt-1">{typeCountMap.get(t.slug) ?? 0} active jobs</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest jobs -->
    <section class="py-12 px-6 max-w-[1200px] mx-auto border-t border-hairline">
      <div class="flex items-baseline justify-between flex-wrap gap-4 mb-6">
        <h2 class="text-[22px] font-semibold leading-[1.18] tracking-[-0.44px] text-ink m-0 [text-wrap:balance]">
          Latest Jobs
        </h2>
        <a href="/jobs" class="text-sm font-medium text-ink underline underline-offset-2 hover:text-primary transition-colors">
          View all jobs →
        </a>
      </div>
      {latestJobs.length === 0 ? (
        <p class="text-base text-muted">No active jobs right now. Check back soon.</p>
      ) : (
        <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
          {latestJobs.map((job) => <JobCard job={job} />)}
        </div>
      )}
    </section>

    <!-- Featured states -->
    {featuredStates.length > 0 && (
      <section class="py-8 px-6 max-w-[1200px] mx-auto border-t border-hairline">
        <div class="flex items-baseline justify-between flex-wrap gap-4 mb-4">
          <h2 class="text-[22px] font-semibold leading-[1.18] tracking-[-0.44px] text-ink m-0 [text-wrap:balance]">
            Browse by State
          </h2>
          <a href="/states" class="text-sm font-medium text-ink underline underline-offset-2 hover:text-primary transition-colors">
            View all states →
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          {featuredStates.map((s) => (
            <a
              href={`/state/${s.slug}`}
              class="block p-3 sm:p-4 bg-canvas rounded-[10px] border border-hairline no-underline text-ink hover:border-hairline-strong hover:shadow-card transition-[border-color,box-shadow] focus-visible:ring-2 focus-visible:ring-ink focus-visible:outline-none"
            >
              <div class="text-sm sm:text-base font-semibold text-ink truncate">{s.name}</div>
              <div class="text-xs sm:text-sm text-muted mt-0.5">{s.count} jobs</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Browse by category -->
    <section class="py-8 px-6 max-w-[1200px] mx-auto border-t border-hairline">
      <h2 class="text-[22px] font-semibold leading-[1.18] tracking-[-0.44px] text-ink mb-4 [text-wrap:balance]">
        Browse by Category
      </h2>
      <div class="flex flex-wrap gap-2">
        {categories.map((c) => (
          <a href={`/category/${c.slug}`} class="category-chip">{c.name}</a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>
