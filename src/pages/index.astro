---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import JobCard from '../components/JobCard.astro';
import { getDb } from '../lib/db';

const db = getDb();

const jobTypes = [
  { slug: 'government', name: 'Government' },
  { slug: 'psu',        name: 'PSU / Semi-Govt' },
  { slug: 'private',    name: 'Private' },
  { slug: 'freelance',  name: 'Freelance / Gig' },
];

const [totalRes, typeCountsRes, latestRes, featuredStatesRes, categoriesRes] = await Promise.all([
  db
    .prepare(`SELECT COUNT(*) AS n FROM jobs WHERE is_published = 1 AND last_date >= DATE('now')`)
    .first<{ n: number }>(),
  db
    .prepare(
      `SELECT jt.slug AS slug, COUNT(*) AS count
       FROM jobs j JOIN job_types jt ON j.job_type_id = jt.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       GROUP BY jt.slug`
    )
    .all(),
  db
    .prepare(
      `SELECT j.id, j.slug, j.title, j.last_date, j.vacancies, j.salary,
              jt.name AS type_name, jt.slug AS type_slug,
              s.name AS state_name, d.name AS dept_name
       FROM jobs j
       LEFT JOIN job_types jt ON j.job_type_id = jt.id
       LEFT JOIN states s ON j.state_id = s.id
       LEFT JOIN departments d ON j.department_id = d.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       ORDER BY j.created_at DESC LIMIT 10`
    )
    .all(),
  db
    .prepare(
      `SELECT s.name, s.slug, COUNT(j.id) AS count
       FROM states s JOIN jobs j ON j.state_id = s.id
       WHERE j.is_published = 1 AND j.last_date >= DATE('now')
       GROUP BY s.id ORDER BY count DESC LIMIT 8`
    )
    .all(),
  db.prepare(`SELECT name, slug FROM categories ORDER BY name`).all(),
]);

const totalCount = totalRes?.n ?? 0;

const typeCountMap = new Map<string, number>(
  (typeCountsRes.results as { slug: string; count: number }[]).map((r) => [r.slug, r.count])
);

const latestJobs = latestRes.results as Array<{
  id: number;
  slug: string;
  title: string;
  last_date: string;
  vacancies: number | null;
  salary: string | null;
  type_name: string | null;
  type_slug: string | null;
  state_name: string | null;
  dept_name: string | null;
}>;

const featuredStates = featuredStatesRes.results as Array<{
  name: string;
  slug: string;
  count: number;
}>;

const categories = categoriesRes.results as Array<{ name: string; slug: string }>;

const quickLinks = [
  { label: 'UPSC',     href: '/jobs?q=UPSC' },
  { label: 'SSC',      href: '/jobs?q=SSC' },
  { label: 'Railways', href: '/category/railways' },
  { label: 'Banking',  href: '/category/banking' },
  { label: 'Defence',  href: '/category/defence' },
];

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/`;
---
<BaseLayout
  title="SarkariNaukriBoard — Government & Private Jobs in India 2026"
  description="Find latest government, PSU and private sector jobs across India. Browse by state, category and job type. Updated daily."
  canonical={canonical}
>
  <main id="main-content">

    <!-- Hero -->
    <section class="bg-canvas-soft border-b border-hairline py-24 px-6">
      <div class="max-w-[960px] mx-auto text-center">
        <h1 class="text-balance text-[48px] font-semibold leading-[48px] tracking-[-2.4px] text-ink mb-4">
          Find Your Dream Government Job
        </h1>
        <p class="text-lg leading-7 text-body mb-8">
          Browse {totalCount} sarkari and private jobs across India.
        </p>

        <form action="/jobs" method="get" role="search" class="flex gap-2 max-w-[560px] mx-auto mb-6 flex-wrap">
          <input
            type="search"
            name="q"
            placeholder="Search jobs by title, department…"
            aria-label="Search jobs"
            autocomplete="off"
            class="flex-[1_1_280px] h-12 px-3 font-sans text-base text-ink bg-canvas border border-hairline rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:border-transparent transition-shadow"
          />
          <button
            type="submit"
            class="h-12 px-6 font-sans text-base font-medium text-on-primary bg-ink border-none rounded-pill cursor-pointer hover:bg-[#2e2e2e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ink focus-visible:ring-offset-2 transition-colors"
          >
            Search
          </button>
        </form>

        <div class="flex gap-2 flex-wrap justify-center">
          {quickLinks.map((q) => (
            <a
              href={q.href}
              class="inline-block px-4 py-1.5 text-sm text-body bg-canvas border border-hairline rounded-pill-sm hover:bg-canvas-soft-2 hover:border-hairline-strong transition-colors"
            >
              {q.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Job-type cards -->
    <section class="py-16 px-6 max-w-[1200px] mx-auto">
      <h2 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink mb-6">
        Browse by Job Type
      </h2>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-4">
        {jobTypes.map((t) => (
          <a
            href={`/jobs?type=${t.slug}`}
            class="block p-6 bg-canvas rounded-md text-ink no-underline shadow-card hover:shadow-card-hover transition-all"
          >
            <div class="text-2xl font-semibold leading-8 tracking-[-0.96px]">
              {t.name}
            </div>
            <div class="text-sm text-muted mt-1">
              {typeCountMap.get(t.slug) ?? 0} active jobs
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest jobs -->
    <section class="py-16 px-6 max-w-[1200px] mx-auto border-t border-hairline">
      <div class="flex items-baseline justify-between flex-wrap gap-4 mb-6">
        <h2 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink m-0">
          Latest Jobs
        </h2>
        <a href="/jobs" class="text-base text-link hover:underline">View all jobs →</a>
      </div>
      {latestJobs.length === 0 ? (
        <p class="text-body">No active jobs right now. Check back soon.</p>
      ) : (
        <div class="grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
          {latestJobs.map((job) => <JobCard job={job} />)}
        </div>
      )}
    </section>

    <!-- Featured states -->
    {featuredStates.length > 0 && (
      <section class="py-16 px-6 max-w-[1200px] mx-auto border-t border-hairline">
        <div class="flex items-baseline justify-between flex-wrap gap-4 mb-6">
          <h2 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink m-0">
            Browse by State
          </h2>
          <a href="/states" class="text-base text-link hover:underline">View all states →</a>
        </div>
        <div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3">
          {featuredStates.map((s) => (
            <a
              href={`/state/${s.slug}`}
              class="block p-4 bg-canvas-soft border border-hairline rounded-md text-ink no-underline hover:bg-canvas-soft-2 hover:border-hairline-strong transition-colors"
            >
              <div class="text-base font-medium">{s.name}</div>
              <div class="text-sm text-muted mt-0.5">{s.count} jobs</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Browse by category -->
    <section class="py-16 px-6 max-w-[1200px] mx-auto border-t border-hairline">
      <h2 class="text-balance text-[32px] font-semibold leading-10 tracking-[-1.28px] text-ink mb-6">
        Browse by Category
      </h2>
      <div class="flex flex-wrap gap-2">
        {categories.map((c) => (
          <a
            href={`/category/${c.slug}`}
            class="inline-block px-4 py-2 text-sm text-ink bg-canvas border border-hairline rounded-pill-sm no-underline hover:bg-canvas-soft-2 hover:border-hairline-strong transition-colors"
          >
            {c.name}
          </a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>
