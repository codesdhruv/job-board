---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = ((env as any).SITE_URL ?? '').replace(/\/$/, '');
const canonical = `${siteUrl}/contact`;
---
<BaseLayout
  title="Contact Us — SarkariNaukriBoard"
  description="Contact SarkariNaukriBoard. Reach out via email for questions, corrections or partnership."
  canonical={canonical}
>
  <main id="main-content" class="max-w-[720px] mx-auto px-6 py-16">
    <h1 class="text-balance text-[40px] font-semibold leading-[48px] tracking-[-1.6px] text-ink mb-6">
      Contact Us
    </h1>
    <p class="text-base leading-7 text-body mb-8">
      Have a question, found an incorrect listing, or want to discuss a partnership? Drop us an email and we'll get back to you as soon as possible.
    </p>
    <div class="inline-block p-6 bg-canvas-soft border border-hairline rounded-md">
      <p class="font-mono text-[11px] uppercase tracking-[0.06em] text-muted mb-1">Email</p>
      <a
        href="mailto:contact@yourdomain.com"
        class="text-lg text-link font-medium hover:underline"
      >
        contact@yourdomain.com
      </a>
    </div>
  </main>
</BaseLayout>
